{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite -c build/vite.config.ts",
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "build:server": "tsc -p tsconfig.build.json",
    "build:client": "vite build -c build/vite.config.ts",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 2
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.0.1",
    "geist": "^1.7.1",
    "helmet": "^8.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsx": "^4.22.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.13.0",
    "postcss": "^8.5.15",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.21"
  }
}
